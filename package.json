{
  "name": "buildfleet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "buildfleet": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:app-server:types": "codex app-server generate-ts --out ./src/generated/app-server/types",
    "generate:app-server:schemas": "codex app-server generate-json-schema --out ./schemas"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0"
  }
}
