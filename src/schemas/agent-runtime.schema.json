{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codefleet/runtime/agents.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updatedAt", "agents"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "provider", "status", "pid", "cwd", "startedAt", "lastHeartbeatAt"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": ["Orchestrator", "Curator", "Developer", "Polisher", "Gatekeeper", "Reviewer"]
          },
          "provider": { "type": "string", "enum": ["codex-app-server", "claude-agent-sdk"] },
          "status": { "type": "string", "enum": ["starting", "running", "stopped", "failed"] },
          "pid": {
            "anyOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "null" }
            ]
          },
          "cwd": { "type": "string", "minLength": 1 },
          "startedAt": { "type": "string", "format": "date-time" },
          "lastHeartbeatAt": { "type": "string", "format": "date-time" },
          "lastError": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
