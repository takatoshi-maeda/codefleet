{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codefleet/runtime/agent-sessions.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updatedAt", "sessions"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agentId", "provider", "status", "initialized", "lastActivityAt"],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "enum": ["codex-app-server", "claude-agent-sdk"] },
          "status": { "type": "string", "enum": ["disconnected", "initializing", "ready", "error"] },
          "initialized": { "type": "boolean" },
          "conversationId": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              { "type": "null" }
            ]
          },
          "activeInvocationId": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              { "type": "null" }
            ]
          },
          "lastActivityAt": { "type": "string", "format": "date-time" },
          "lastError": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
